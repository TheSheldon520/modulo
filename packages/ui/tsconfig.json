{
  "extends": "@modulo/tsconfig/base",
  "compilerOptions": {
    "lib": ["DOM", "DOM.Iterable", "ES2022"],
    "jsx": "preserve",
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./*"]
    }
  },
  "include": ["components/**/*.ts", "components/**/*.tsx", "lib/**/*.ts", "lib/**/*.test.ts", "vitest.config.ts"],
  "exclude": ["node_modules", "dist", ".turbo"]
}
