# Modulo — environment variables
# Copy this file to `.env.local` at the repo root and fill in real values.
# `.env.local` is git-ignored; every workspace package reads it from the root.

# --- Database (Neon Postgres) ---------------------------------------------

# Pooled connection — used by the application at runtime (@modulo/db client).
# Host contains "-pooler" and points to the Neon connection pooler.
DATABASE_URL="postgresql://USER:PASSWORD@HOST-pooler.REGION.aws.neon.tech/DBNAME?sslmode=require"

# Direct (unpooled) connection — used by Drizzle Kit for migrations
# (db:migrate / db:push / db:studio). Host has no "-pooler" segment.
DATABASE_URL_UNPOOLED="postgresql://USER:PASSWORD@HOST.REGION.aws.neon.tech/DBNAME?sslmode=require"

# --- Better Auth ----------------------------------------------------------

BETTER_AUTH_SECRET=replace-with-output-of-openssl-rand-base64-32
BETTER_AUTH_URL=http://localhost:3000

# GitHub OAuth — https://github.com/settings/developers
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Google OAuth — https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Stripe (test mode) ---------------------------------------------------

# Server-side secret key (sk_test_...) — never expose to the client bundle.
STRIPE_SECRET_KEY=sk_test_xxx
# Publishable key (pk_test_...) — safe to ship to the client (not used yet
# in T0.9: Checkout redirects are server-side, no Stripe.js mount needed).
STRIPE_PUBLISHABLE_KEY=pk_test_xxx
# Price ID for the Sales Analytics module subscription.
STRIPE_PRICE_SALES_ANALYTICS=price_xxx
# Webhook signing secret — printed by `stripe listen --forward-to
# localhost:3000/api/webhooks/stripe` when forwarding events locally.
# Required ONLY inside the webhook handler (read lazily, fail loud).
STRIPE_WEBHOOK_SECRET=whsec_xxx
