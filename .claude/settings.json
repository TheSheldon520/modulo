{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(pnpm install)",
      "Bash(pnpm install:*)",
      "Bash(pnpm add:*)",
      "Bash(pnpm typecheck)",
      "Bash(pnpm typecheck:*)",
      "Bash(pnpm lint)",
      "Bash(pnpm lint:*)",
      "Bash(pnpm test)",
      "Bash(pnpm test:*)",
      "Bash(pnpm dev)",
      "Bash(pnpm build)",
      "Bash(pnpm db:generate)",
      "Bash(pnpm db:generate:*)",
      "Bash(pnpm db:studio)",
      "Bash(pnpm db:push)",
      "Bash(pnpm module:new:*)",
      "Bash(pnpm dlx:*)",
      "Bash(pnpm exec:*)",
      "Bash(pnpx:*)",
      "Bash(npx:*)",
      "Bash(turbo:*)",
      "Bash(git status)",
      "Bash(git status:*)",
      "Bash(git diff)",
      "Bash(git diff:*)",
      "Bash(git log)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(git branch)",
      "Bash(git branch:*)",
      "Bash(ls)",
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(mkdir:*)",
      "Bash(touch:*)",
      "Read",
      "Glob",
      "Grep"
    ],
    "deny": [
      "Bash(rm -rf:*)",
      "Bash(rm -rf /:*)",
      "Bash(sudo:*)",
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(git reset --hard:*)",
      "Bash(git clean -fd:*)",
      "Bash(git checkout -- .)",
      "Bash(git filter-branch:*)",
      "Bash(curl:*)",
      "Bash(wget:*)",
      "Read(.env)",
      "Read(.env.local)",
      "Read(.env.*.local)",
      "Read(**/.env)",
      "Read(**/.env.local)",
      "Read(**/.env.*.local)",
      "Write(.env)",
      "Write(.env.local)",
      "Write(.env.*.local)",
      "Edit(.env)",
      "Edit(.env.local)"
    ],
    "ask": [
      "Bash(git commit:*)",
      "Bash(git push:*)",
      "Bash(git merge:*)",
      "Bash(git rebase:*)",
      "Bash(pnpm db:migrate)",
      "Bash(pnpm db:migrate:*)",
      "Bash(pnpm db:drop:*)",
      "Bash(pnpm remove:*)",
      "Write(packages/db/schema/core.ts)",
      "Write(packages/db/schema/billing.ts)",
      "Edit(packages/db/schema/core.ts)",
      "Edit(packages/db/schema/billing.ts)",
      "Write(CLAUDE.md)",
      "Edit(CLAUDE.md)",
      "Write(docs/ARCHITECTURE.md)",
      "Edit(docs/ARCHITECTURE.md)",
      "Write(turbo.json)",
      "Edit(turbo.json)",
      "Write(pnpm-workspace.yaml)",
      "Edit(pnpm-workspace.yaml)"
    ]
  },
  "outputStyle": "default"
}
